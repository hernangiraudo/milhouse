{
  "name": "Demo financiero · scoring de fraude",
  "version": 1,
  "duckdb_path": "data/demo.duckdb",
  "groups": [
    {
      "name": "prepare",
      "description": "Preparación de la base (DDL y materializaciones).",
      "color": null
    },
    {
      "name": "ingest",
      "description": "Carga de tablas desde la base hacia memoria.",
      "color": null
    },
    {
      "name": "enrich",
      "description": "Joins y lookups para denormalizar.",
      "color": null
    },
    {
      "name": "transform",
      "description": "Transformaciones de tipos y filtros.",
      "color": null
    },
    {
      "name": "score",
      "description": "Lógica fila-por-fila: scoring de fraude.",
      "color": null
    },
    {
      "name": "export",
      "description": "Salidas a archivos o tablas.",
      "color": null
    }
  ],
  "steps": [
    {
      "step_uid": 1,
      "id": "prepare_db",
      "depends_on": [],
      "group": "prepare",
      "kind": "sql_exec",
      "query": "CREATE OR REPLACE TABLE tx_recent AS SELECT * FROM transactions WHERE CAST(timestamp AS TIMESTAMP) >= (CURRENT_TIMESTAMP::TIMESTAMP - INTERVAL 365 DAY); CREATE INDEX IF NOT EXISTS idx_tx_recent_account ON tx_recent(account_id);",
      "connection": null
    },
    {
      "step_uid": 2,
      "id": "load_currencies",
      "depends_on": [
        "prepare_db"
      ],
      "group": "ingest",
      "kind": "sql_query",
      "query": "SELECT id AS currency_id, code, symbol, rate_to_usd FROM currencies",
      "connection": null,
      "output_table": "currencies"
    },
    {
      "step_uid": 3,
      "id": "load_categories",
      "depends_on": [
        "prepare_db"
      ],
      "group": "ingest",
      "kind": "sql_query",
      "query": "SELECT id AS category_id, name AS category_name, parent_id FROM categories",
      "connection": null,
      "output_table": "categories"
    },
    {
      "step_uid": 4,
      "id": "load_accounts",
      "depends_on": [
        "prepare_db"
      ],
      "group": "ingest",
      "kind": "sql_query",
      "query": "SELECT id AS account_id, owner_name, country AS account_country, currency_id AS account_currency_id, opened_at FROM accounts",
      "connection": null,
      "output_table": "accounts"
    },
    {
      "step_uid": 5,
      "id": "load_transactions",
      "depends_on": [
        "prepare_db"
      ],
      "group": "ingest",
      "kind": "sql_query",
      "query": "SELECT tx_id, account_id, category_id, amount, currency_id, timestamp, country, status FROM tx_recent",
      "connection": null,
      "output_table": "tx_raw"
    },
    {
      "step_uid": 6,
      "id": "join_tx_accounts",
      "depends_on": [
        "load_transactions",
        "load_accounts"
      ],
      "group": "enrich",
      "kind": "join",
      "left": "tx_raw",
      "right": "accounts",
      "left_on": [
        "account_id"
      ],
      "right_on": [
        "account_id"
      ],
      "how": "inner",
      "output_table": "tx_with_account"
    },
    {
      "step_uid": 7,
      "id": "lookup_currency",
      "depends_on": [
        "join_tx_accounts",
        "load_currencies"
      ],
      "group": "enrich",
      "kind": "lookup",
      "input": "tx_with_account",
      "master": "currencies",
      "key": "currency_id",
      "master_key": "currency_id",
      "select": [
        {
          "from": "code",
          "as": "currency_code"
        },
        {
          "from": "rate_to_usd",
          "as": "currency_rate"
        }
      ],
      "output_table": "tx_with_currency"
    },
    {
      "step_uid": 8,
      "id": "lookup_categories",
      "depends_on": [
        "lookup_currency",
        "load_categories"
      ],
      "group": "enrich",
      "kind": "lookup",
      "input": "tx_with_currency",
      "master": "categories",
      "key": "category_id",
      "master_key": "category_id",
      "select": [
        {
          "from": "category_name",
          "as": "category_name"
        }
      ],
      "output_table": "tx_enriched"
    },
    {
      "step_uid": 9,
      "id": "tx_date",
      "depends_on": [
        "lookup_categories"
      ],
      "group": "transform",
      "kind": "transform",
      "input": "tx_enriched",
      "operations": [
        {
          "op": "to_date",
          "column": "timestamp",
          "format": "%Y-%m-%d %H:%M:%S%.f",
          "as": "date"
        },
        {
          "op": "uppercase",
          "column": "country",
          "as": "country"
        },
        {
          "op": "cast",
          "column": "amount",
          "to": "f64",
          "as": null
        }
      ],
      "output_table": "tx_typed"
    },
    {
      "step_uid": 10,
      "id": "filter_large_tx",
      "depends_on": [
        "tx_date"
      ],
      "group": "transform",
      "kind": "filter_and_subset",
      "input": "tx_typed",
      "filter": "amount > 1000 AND status == 'ok'",
      "select": [
        "tx_id",
        "date",
        "amount",
        "account_id",
        "currency_code",
        "category_name",
        "country",
        "account_country"
      ],
      "output_table": "tx_large"
    },
    {
      "step_uid": 11,
      "id": "fraud_score_rhai",
      "depends_on": [
        "tx_date"
      ],
      "group": "score",
      "log_level": "warn",
      "dataset_name": "scoring_rhai_resultados",
      "kind": "procedural",
      "input": "tx_typed",
      "engine": "rhai",
      "script": "state.sum_amount += row.amount; if row.amount > 5000.0 && row.country != row.account_country { state.flagged += 1; row.score_rhai = 0.9; row.flag_rhai = true; } else { row.score_rhai = 0.1; row.flag_rhai = false; } row",
      "fn_name": null,
      "params": null,
      "state_init": {
        "flagged": 0,
        "sum_amount": 0.0
      },
      "output_table": "tx_scored_rhai"
    },
    {
      "step_uid": 12,
      "id": "fraud_score_rust",
      "depends_on": [
        "tx_date"
      ],
      "group": "score",
      "log_level": "error",
      "dataset_name": "scoring_rust_resultados",
      "kind": "procedural",
      "input": "tx_typed",
      "engine": "rust",
      "script": null,
      "fn_name": "fraud_scoring_v1",
      "params": {
        "threshold": 5000.0
      },
      "state_init": null,
      "output_table": "tx_scored_rust"
    },
    {
      "step_uid": 13,
      "id": "sort_tx_large",
      "depends_on": [
        "filter_large_tx"
      ],
      "group": "transform",
      "kind": "sort",
      "input": "tx_large",
      "by": [
        {
          "column": "date",
          "desc": false
        },
        {
          "column": "amount",
          "desc": true
        }
      ],
      "output_table": "tx_large_sorted"
    },
    {
      "step_uid": 14,
      "id": "join_scores",
      "depends_on": [
        "fraud_score_rhai",
        "fraud_score_rust"
      ],
      "group": "score",
      "kind": "join",
      "left": "tx_scored_rhai",
      "right": "tx_scored_rust",
      "left_on": [
        "tx_id"
      ],
      "right_on": [
        "tx_id"
      ],
      "how": "inner",
      "output_table": "tx_scores"
    },
    {
      "step_uid": 15,
      "id": "export_large_csv",
      "depends_on": [
        "sort_tx_large"
      ],
      "group": "export",
      "kind": "export",
      "input": "tx_large_sorted",
      "target": {
        "kind": "file",
        "format": "csv",
        "path": "data/exports/tx_large_sorted.csv"
      }
    },
    {
      "step_uid": 16,
      "id": "export_scores_parquet",
      "depends_on": [
        "join_scores"
      ],
      "group": "export",
      "kind": "export",
      "input": "tx_scores",
      "target": {
        "kind": "file",
        "format": "parquet",
        "path": "data/exports/tx_scores.parquet"
      }
    }
  ]
}