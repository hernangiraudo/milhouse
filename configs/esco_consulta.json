{
  "name": "Esco Consulta",
  "version": 1,
  "duckdb_path": null,
  "groups": [
    {
      "name": "ingest",
      "description": "Carga de datos desde la base operativa.",
      "color": null
    },
    {
      "name": "export",
      "description": "Resultado a archivo.",
      "color": null
    }
  ],
  "steps": [
    {
      "step_uid": 1,
      "id": "load_currencies",
      "depends_on": [],
      "group": "ingest",
      "log_level": "info",
      "dataset_name": null,
      "kind": "sql_query",
      "query": "SELECT id AS currency_id, code, symbol, rate_to_usd FROM currencies",
      "connection": null,
      "output_table": "currencies"
    },
    {
      "step_uid": 2,
      "id": "load_accounts",
      "depends_on": [],
      "group": "ingest",
      "log_level": "info",
      "dataset_name": null,
      "kind": "sql_query",
      "query": "SELECT id AS account_id, owner_name, country, currency_id, opened_at FROM accounts",
      "connection": null,
      "output_table": "accounts"
    },
    {
      "step_uid": 3,
      "id": "export_consulta",
      "depends_on": [
        "load_accounts"
      ],
      "group": "export",
      "log_level": "info",
      "dataset_name": null,
      "kind": "export",
      "input": "accounts",
      "target": {
        "kind": "file",
        "format": "csv",
        "path": "data/exports/esco_consulta.csv"
      }
    }
  ]
}