{
  "name": "Rendimiento Especie - Informe",
  "version": 1,
  "steps": [
    {
      "id": "load_summary",
      "kind": "sql_query",
      "depends_on": [],
      "query": "SELECT account_id, COUNT(*) AS tx_count, SUM(amount) AS total_amount FROM transactions GROUP BY account_id ORDER BY total_amount DESC",
      "output_table": "summary"
    },
    {
      "id": "top_accounts",
      "kind": "filter_and_subset",
      "depends_on": ["load_summary"],
      "input": "summary",
      "filter": "tx_count > 50",
      "select": ["account_id", "tx_count", "total_amount"],
      "output_table": "top"
    },
    {
      "id": "export_informe",
      "kind": "export",
      "depends_on": ["top_accounts"],
      "input": "top",
      "target": { "kind": "file", "format": "csv", "path": "data/exports/rend_especie_informe.csv" }
    }
  ]
}
