{
  "name": "Rendimiento Especie - Ajuste",
  "version": 1,
  "steps": [
    {
      "id": "load_tx",
      "kind": "sql_query",
      "depends_on": [],
      "query": "SELECT tx_id, account_id, amount, currency_id, timestamp FROM transactions",
      "output_table": "tx"
    },
    {
      "id": "load_currencies",
      "kind": "sql_query",
      "depends_on": [],
      "query": "SELECT id AS currency_id, code, rate_to_usd FROM currencies",
      "output_table": "currencies"
    },
    {
      "id": "lookup_rate",
      "kind": "lookup",
      "depends_on": ["load_tx", "load_currencies"],
      "input": "tx",
      "master": "currencies",
      "key": "currency_id",
      "master_key": "currency_id",
      "select": [
        { "from": "code", "as": "currency_code" },
        { "from": "rate_to_usd", "as": "rate_to_usd" }
      ],
      "output_table": "tx_with_rate"
    }
  ]
}
